{
  "name": "riskflow-ui",
  "private": true,
  "version": "0.8.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "lint:boundaries": "tsx tools/import-boundary-linter.ts",
    "generate:types": "openapi-typescript openapi.json -o src/types/api.generated.ts --export-type && prettier --write src/types/api.generated.ts",
    "sync:openapi": "cp ../riskflow/openapi.json openapi.json && npm run generate:types",
    "test:unit": "vitest run src/ --exclude \"**/*.integration.test.*\"",
    "test:integration": "vitest run integration --outputFile.junit=reports/integration.xml",
    "test:unit:watch": "vitest src/ --exclude \"**/*.integration.test.*\""
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
