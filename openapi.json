    "/upload": {
      "post": {
        "summary": "Upload File",
        "description": "Upload a spreadsheet and map its headers to the target schema.",
        "operationId": "upload_file_upload_post",
        "parameters": [
          {
            "name": "sheet_name",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Sheet name for multi-sheet Excel files",
              "title": "Sheet Name"
            },
            "description": "Sheet name for multi-sheet Excel files"
          },
          {
            "name": "cedent_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Cedent ID for correction cache lookup",
              "title": "Cedent Id"
            },
            "description": "Cedent ID for correction cache lookup"
          },
          {
            "name": "schema",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Schema name to use (from GET /schemas)",
              "title": "Schema"
            },
            "description": "Schema name to use (from GET /schemas)"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_file_upload_post"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProcessingResult"
                }
              }
            }
          },
          "400": {
            "description": "Invalid data or sheet name",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDetail"
                }
              }
            }
          },
          "422": {
            "description": "Low confidence or schema validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDetail"
                }
              }
            }
          },
          "503": {
            "description": "SLM unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDetail"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorDetail"
                }
              }
            }
          }
        }
      }
    },
