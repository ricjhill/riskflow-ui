      "ColumnMapping": {
        "properties": {
          "source_header": {
            "type": "string",
            "title": "Source Header"
          },
          "target_field": {
            "type": "string",
            "title": "Target Field"
          },
          "confidence": {
            "type": "number",
            "title": "Confidence"
          }
        },
        "type": "object",
        "required": [
          "source_header",
          "target_field",
          "confidence"
        ],
        "title": "ColumnMapping",
        "description": "Maps a source spreadsheet header to a target schema field.\n\ntarget_field is not validated here \u2014 it's validated at the\nMappingResult level via validate_against_schema() where the\nTargetSchema is known. This allows ColumnMapping to work with\nany schema, not just the hardcoded default."
      },
      "ConfidenceReport": {
        "properties": {
          "min_confidence": {
            "type": "number",
            "title": "Min Confidence"
          },
          "avg_confidence": {
            "type": "number",
            "title": "Avg Confidence"
          },
          "low_confidence_fields": {
            "items": {
              "$ref": "#/components/schemas/ColumnMapping"
            },
            "type": "array",
            "title": "Low Confidence Fields"
          },
          "missing_fields": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Missing Fields"
          }
        },
        "type": "object",
        "required": [
          "min_confidence",
          "avg_confidence",
          "low_confidence_fields",
          "missing_fields"
        ],
        "title": "ConfidenceReport",
        "description": "Summarizes mapping quality for human review.\n\nBuilt from a MappingResult, this report highlights:\n- Overall confidence (min and average)\n- Which fields have low confidence and need review\n- Which target fields were not mapped at all"
      },
