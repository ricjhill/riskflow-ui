{
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git add:*)",
      "Bash(git push:*)",
      "Bash(git push)",
      "Bash(gh:*)",
      "Bash(ls:*)",
      "Bash(ls)",
      "Bash(lsof -ti:5173)",
      "Bash(lsof -ti:5174)",
      "Bash(uvx rodney:*)",
      "Read(//home/ric/.claude/plans/**)",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "Bash(bash -c ':*)",
      "Bash(python3 -c \"import json; print\\(json.dumps\\({'test': 1}\\)\\)\")"
    ],
    "deny": [
      "Edit(package-lock.json)",
      "Edit(.env)",
      "Bash(git push --force:*)"
    ],
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-boundaries.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/security-scan.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": ".claude/hooks/enforce-create-pr.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/protect-files.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-format.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-failure-context.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/post-rename-check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/post-merge-verify.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": ".claude/hooks/post-issue-validate.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
